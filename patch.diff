+#!/usr/bin/env bash
+#
+# Curl usage examples for the Data Broker Read API.
+# Each command can be run independently.
+# Adjust BASE_URL, user IDs, league IDs, etc. for your environment.
+
+BASE_URL="http://localhost:3000"
+
+echo "=== User Data Endpoints ==="
+echo ""
+
+echo "# Get default league/season for a user"
+echo 'curl -s "$BASE_URL/api/user/testuser1/default-league-season" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/default-league-season" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Get enabled features for a user"
+echo 'curl -s "$BASE_URL/api/user/testuser1/features" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/features" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Get iRacing link state for a user"
+echo 'curl -s "$BASE_URL/api/user/testuser1/ir-link-state" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/ir-link-state" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Get leagues a user is interested in"
+echo 'curl -s "$BASE_URL/api/user/testuser1/leagues" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/leagues" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Resolve user context (auto-detect closest event)"
+echo 'curl -s "$BASE_URL/api/user/testuser1/context" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/context" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Resolve user context for a specific league"
+echo 'curl -s "$BASE_URL/api/user/testuser1/context?league=6555" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/context?league=6555" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Resolve user context for a specific league and season"
+echo 'curl -s "$BASE_URL/api/user/testuser1/context?league=6555&season=99410" | jq .'
+curl -s "$BASE_URL/api/user/testuser1/context?league=6555&season=99410" | jq . 2>/dev/null || true
+echo ""
+
+echo "=== Config Endpoints ==="
+echo ""
+
+echo "# Get teams and members for a league"
+echo 'curl -s "$BASE_URL/api/config/leagues/6555/teams" | jq .'
+curl -s "$BASE_URL/api/config/leagues/6555/teams" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Get active league schedule"
+echo 'curl -s "$BASE_URL/api/config/active-league-schedule" | jq .'
+curl -s "$BASE_URL/api/config/active-league-schedule" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Get track display information"
+echo 'curl -s "$BASE_URL/api/config/tracks" | jq .'
+curl -s "$BASE_URL/api/config/tracks" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Resolve config context (no user)"
+echo 'curl -s "$BASE_URL/api/config/context" | jq .'
+curl -s "$BASE_URL/api/config/context" | jq . 2>/dev/null || true
+echo ""
+
+echo "=== Publication Endpoints ==="
+echo ""
+
+echo "# Check if a subsession has been published"
+echo 'curl -s "$BASE_URL/api/publications/12345/status" | jq .'
+curl -s "$BASE_URL/api/publications/12345/status" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Invalid subsession ID returns 400"
+echo 'curl -s -w "\nHTTP %{http_code}\n" "$BASE_URL/api/publications/notanumber/status"'
+curl -s -w "\nHTTP %{http_code}\n" "$BASE_URL/api/publications/notanumber/status" 2>/dev/null || true
+echo ""
+
+echo "=== Channel Endpoints ==="
+echo ""
+
+echo "# Get user ID mappings for a channel"
+echo 'curl -s "$BASE_URL/api/channels/ch001/users" | jq .'
+curl -s "$BASE_URL/api/channels/ch001/users" | jq . 2>/dev/null || true
+echo ""
+
+echo "=== Data Lake Endpoints ==="
+echo ""
+
+echo "# Fetch league seasons from data lake"
+echo 'curl -s "$BASE_URL/api/datalake/ldata-irweb/leagueSeasons?league=6555" | jq .'
+curl -s "$BASE_URL/api/datalake/ldata-irweb/leagueSeasons?league=6555" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Fetch league season sessions from data lake"
+echo 'curl -s "$BASE_URL/api/datalake/ldata-irweb/leagueSeasonSessions?league=6555&season=99410" | jq .'
+curl -s "$BASE_URL/api/datalake/ldata-irweb/leagueSeasonSessions?league=6555&season=99410" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Fetch driver stats from data lake"
+echo 'curl -s "$BASE_URL/api/datalake/ldata-rsltsts/leagueDriverStats?league=6555" | jq .'
+curl -s "$BASE_URL/api/datalake/ldata-rsltsts/leagueDriverStats?league=6555" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Fetch single member data from data lake"
+echo 'curl -s "$BASE_URL/api/datalake/ldata-rsltsts/singleMemberData?driver=123456" | jq .'
+curl -s "$BASE_URL/api/datalake/ldata-rsltsts/singleMemberData?driver=123456" | jq . 2>/dev/null || true
+echo ""
+
+echo "# Fetch members data for a league season"
+echo 'curl -s "$BASE_URL/api/datalake/ldata-irweb/membersData?league=6555&season=99410" | jq .'
+curl -s "$BASE_URL/api/datalake/ldata-irweb/membersData?league=6555&season=99410" | jq . 2>/dev/null || true
+echo ""
diff --git a/scripts/integration-test.sh b/scripts/integration-test.sh
new file mode 100755
index 0000000..56857a5
--- /dev/null
+++ b/scripts/integration-test.sh
@@ -0,0 +1,180 @@
+#!/usr/bin/env bash
+#
+# Integration tests for Data Broker Read API endpoints.
+# Usage: ./scripts/integration-test.sh [BASE_URL]
+#   BASE_URL defaults to http://localhost:3000
+#
+# Prerequisites: the server must be running (npm run dev)
+#
+# Each test issues a curl request and validates the HTTP status code.
+# Set USER_ID, LEAGUE_ID, SEASON_ID, CHANNEL_ID, SUBSESSION_ID as env vars
+# to test with your own data, or use the defaults below.
+
+set -euo pipefail
+
+BASE_URL="${1:-http://localhost:3030}"
+USER_ID="${USER_ID:-testuser1}"
+LEAGUE_ID="${LEAGUE_ID:-6555}"
+SEASON_ID="${SEASON_ID:-99410}"
+SUBSESSION_ID="${SUBSESSION_ID:-12345}"
+CHANNEL_ID="${CHANNEL_ID:-ch001}"
+
+PASS=0
+FAIL=0
+SKIP=0
+
+green()  { printf "\033[32m%s\033[0m" "$1"; }
+red()    { printf "\033[31m%s\033[0m" "$1"; }
+yellow() { printf "\033[33m%s\033[0m" "$1"; }
+
+# test_endpoint NAME METHOD URL EXPECTED_STATUS
+test_endpoint() {
+    local name="$1"
+    local url="$2"
+    local expected_status="${3:-200}"
+
+    local http_code body
+    body=$(curl -s -o /dev/null -w '%{http_code}' "$url" 2>/dev/null) || true
+    http_code="$body"
+
+    # Get the full response body for display
+    local response
+    response=$(curl -s "$url" 2>/dev/null | head -c 500) || true
+
+    if [ "$http_code" = "$expected_status" ]; then
+        PASS=$((PASS + 1))
+        echo "  $(green "PASS") $name (HTTP $http_code)"
+    else
+        FAIL=$((FAIL + 1))
+        echo "  $(red "FAIL") $name - expected $expected_status, got $http_code"
+    fi
+
+    # Show a truncated response for inspection
+    echo "        curl: $url"
+    echo "        body: ${response:0:200}"
+    echo ""
+}
+
+echo ""
+echo "========================================"
+echo " Data Broker Read API - Integration Test"
+echo " Base URL: $BASE_URL"
+echo "========================================"
+echo ""
+
+# --- Connectivity check ---
+echo "--- Connectivity ---"
+if ! curl -s -o /dev/null -w '' "$BASE_URL/" 2>/dev/null; then
+    echo "  $(red "ERROR") Cannot reach $BASE_URL - is the server running?"
+    echo "  Start with: npm run dev"
+    exit 1
+fi
+echo "  $(green "OK") Server reachable"
+echo ""
+
+# --- User Data Endpoints ---
+echo "--- User Data Endpoints ---"
+
+test_endpoint \
+    "GET /api/user/:userId/default-league-season" \
+    "$BASE_URL/api/user/$USER_ID/default-league-season"
+
+test_endpoint \
+    "GET /api/user/:userId/features" \
+    "$BASE_URL/api/user/$USER_ID/features"
+
+test_endpoint \
+    "GET /api/user/:userId/ir-link-state" \
+    "$BASE_URL/api/user/$USER_ID/ir-link-state"
+
+test_endpoint \
+    "GET /api/user/:userId/leagues" \
+    "$BASE_URL/api/user/$USER_ID/leagues"
+
+test_endpoint \
+    "GET /api/user/:userId/context (no params)" \
+    "$BASE_URL/api/user/$USER_ID/context"
+
+test_endpoint \
+    "GET /api/user/:userId/context (with league)" \
+    "$BASE_URL/api/user/$USER_ID/context?league=$LEAGUE_ID"
+
+test_endpoint \
+    "GET /api/user/:userId/context (with league+season)" \
+    "$BASE_URL/api/user/$USER_ID/context?league=$LEAGUE_ID&season=$SEASON_ID"
+
+test_endpoint \
+    "GET /api/user/:userId/context (with league+season+subsession)" \
+    "$BASE_URL/api/user/$USER_ID/context?league=$LEAGUE_ID&season=$SEASON_ID&subsession=$SUBSESSION_ID"
+
+# --- Config Endpoints ---
+echo "--- Config Endpoints ---"
+
+test_endpoint \
+    "GET /api/config/leagues/:leagueId/teams" \
+    "$BASE_URL/api/config/leagues/$LEAGUE_ID/teams"
+
+test_endpoint \
+    "GET /api/config/active-league-schedule" \
+    "$BASE_URL/api/config/active-league-schedule"
+
+test_endpoint \
+    "GET /api/config/tracks" \
+    "$BASE_URL/api/config/tracks"
+
+test_endpoint \
+    "GET /api/config/context (no params)" \
+    "$BASE_URL/api/config/context"
+
+test_endpoint \
+    "GET /api/config/context (with league)" \
+    "$BASE_URL/api/config/context?league=$LEAGUE_ID"
+
+test_endpoint \
+    "GET /api/config/context (with league+season)" \
+    "$BASE_URL/api/config/context?league=$LEAGUE_ID&season=$SEASON_ID"
+
+# --- Publication Endpoints ---
+echo "--- Publication Endpoints ---"
+
+test_endpoint \
+    "GET /api/publications/:subsessionId/status" \
+    "$BASE_URL/api/publications/$SUBSESSION_ID/status"
+
+test_endpoint \
+    "GET /api/publications/:subsessionId/status (invalid ID)" \
+    "$BASE_URL/api/publications/notanumber/status" \
+    "400"
+
+# --- Channel Endpoints ---
+echo "--- Channel Endpoints ---"
+
+test_endpoint \
+    "GET /api/channels/:channelId/users" \
+    "$BASE_URL/api/channels/$CHANNEL_ID/users"
+
+# --- Data Lake Endpoints ---
+echo "--- Data Lake Endpoints ---"
+
+test_endpoint \
+    "GET /api/datalake/:namespace/:type (league seasons)" \
+    "$BASE_URL/api/datalake/ldata-irweb/leagueSeasons?league=$LEAGUE_ID"
+
+test_endpoint \
+    "GET /api/datalake/:namespace/:type (league season sessions)" \
+    "$BASE_URL/api/datalake/ldata-irweb/leagueSeasonSessions?league=$LEAGUE_ID&season=$SEASON_ID"
+
+test_endpoint \
+    "GET /api/datalake/:namespace/:type (league driver stats)" \
+    "$BASE_URL/api/datalake/ldata-rsltsts/leagueDriverStats?league=$LEAGUE_ID"
+
+test_endpoint \
+    "GET /api/datalake/:namespace/:type (members data)" \

+
+    let teamsA = Object.values(teamViewMap).sort(
+        (a, b) => b.points - a.points
+    );
+
+    teamsA.forEach((v, i) => {
+        v.position = i + 1;
+    });
+
+    if (summaryMode) {
+        teamsA = teamsA.filter((v) => v.position <= 3);
+    }
+
+    return teamsA;

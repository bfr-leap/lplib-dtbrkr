+// GET /user/:userId/ir-link-state
+dtbrkrReadRoutes.get('/user/:userId/ir-link-state', async (c) => {
+    const userId = c.req.param('userId');
+    const data = await userDataHandler('ldata-usrdata', { type: 'irLinkState', userID: userId });
+    return c.json(data);
+});
+
+// GET /user/:userId/leagues
+dtbrkrReadRoutes.get('/user/:userId/leagues', async (c) => {
+    const userId = c.req.param('userId');
+    const data = await userDataHandler('ldata-usrdata', { type: 'userLeagues', userID: userId });
+    return c.json(data);
+});
+
+// GET /user/:userId/context
+dtbrkrReadRoutes.get('/user/:userId/context', async (c) => {
+    const userId = c.req.param('userId');
+    const league = c.req.query('league') || '';
+    const season = c.req.query('season') || '';
+    const subsession = c.req.query('subsession') || '';
+    const data = await userDataHandler('ldata-usrdata', {
+        type: 'defLgSeasSubCtx',
+        userID: userId,
+        league,
+        season,
+        subsession,
+    });
+    return c.json(data);
+});

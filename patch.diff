+// --- Config Endpoints ---
+
+// GET /config/leagues/:leagueId/teams
+dtbrkrReadRoutes.get('/config/leagues/:leagueId/teams', async (c) => {
+    const leagueId = c.req.param('leagueId');
+    const data = await userConfigHandler('ldata-usrcfg', { type: 'leagueTeamsInfo', league: leagueId });
+    return c.json(data);
+});
+
+// GET /config/active-league-schedule
+dtbrkrReadRoutes.get('/config/active-league-schedule', async (c) => {
+    const data = await getActiveLeagueSchedule();
+    return c.json(data);
+});
+
+// GET /config/tracks
+dtbrkrReadRoutes.get('/config/tracks', async (c) => {
+    const data = await userConfigHandler('ldata-usrcfg', { type: 'trackDisplayInfo' });
+    return c.json(data);
+});
+
+// GET /config/context
+dtbrkrReadRoutes.get('/config/context', async (c) => {
+    const league = c.req.query('league') || '';
+    const season = c.req.query('season') || '';
+    const subsession = c.req.query('subsession') || '';
+    const data = await userConfigHandler('ldata-usrcfg', {
+        type: 'defLgSeasSubCtx',
+        league,
+        season,
+        subsession,
+    });
+    return c.json(data);
+});

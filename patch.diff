+
+// GET /publications/:subsessionId/status
+dtbrkrReadRoutes.get('/publications/:subsessionId/status', async (c) => {
+    const subsessionId = Number.parseInt(c.req.param('subsessionId'), 10);
+    if (isNaN(subsessionId)) {
+        return c.json({ error: 'Invalid subsession ID' }, 400);
+    }
+    const published = await isSubsessionPublished(subsessionId);
+    return c.json({ subsession_id: subsessionId, published });
+});
+
+// --- Channel Endpoints ---
+
+// GET /channels/:channelId/users
+dtbrkrReadRoutes.get('/channels/:channelId/users', async (c) => {
+    const channelId = c.req.param('channelId');
+    const data = await loadUserIdsForChannel(channelId);
+    return c.json(data);
+});
+
+// --- Data Lake Endpoints ---
+
+// GET /datalake/:namespace/:type
+dtbrkrReadRoutes.get('/datalake/:namespace/:type', async (c) => {
+    const namespace = c.req.param('namespace');
+    const type = c.req.param('type');
+    const query: { [name: string]: string } = { namespace, type };
+
+    const optionalParams = ['league', 'season', 'subsession', 'simsession', 'driver', 'car', 'track', 'sessionType', 'custId'];
+    for (const param of optionalParams) {
+        const value = c.req.query(param);
+        if (value) query[param] = value;
+    }
+
+    const data = await getDataLakeDocument(query);
+    if (data === null) {
+        return c.json({ error: 'Document not found' }, 404);
+    }
+    return c.json(data);
+});

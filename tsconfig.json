{
    "compilerOptions": {
        "target": "ES6",
        "module": "es2020",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "types": ["vitest/globals", "node"]
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules"]
}
